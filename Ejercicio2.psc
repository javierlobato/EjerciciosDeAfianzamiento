Proceso Ejercicio2
	//Realizar un programa el cual solicite su nombre, apellidos, edad y estatura.
	Definir nombre Como cadena;
	Definir edad Como Entero;
	Definir estatura Como Real;
	
	Escribir "¿Cuál es su nombre y apellidos? ";
	Leer  nombre;
	
	Escribir "¿Cuál es su edad? ";
	Leer edad;
	
	Escribir "¿Cuanto mides en metros? ";
	Leer estatura;
	
	Escribir "Usted se llama ",nombre,", tiene ",edad," años ","y mide ",estatura," metros";

	
FinProceso
