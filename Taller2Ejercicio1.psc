Proceso Taller2Ejercicio1
	//Realizar un programa en el cual se solicite la edad de una persona. 
	//Si la persona es mayor o igual a 18 ańos, deberá mostrar en pantalla: Usted es mayor de edad.
	
	Definir edad Como Entero;
	
	Escribir "Por favor digite su edad: ";
	Leer edad;
	
	Si ( edad >= 18 ) Entonces
		Escribir "Usted es MAYOR de edad";
	SiNo
		Escribir "Sólo para mayores de 18 ańos";
	FinSi
	
FinProceso
