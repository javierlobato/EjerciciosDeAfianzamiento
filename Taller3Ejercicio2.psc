Proceso Taller3Ejercicio2
	
	Definir i,j,k Como Entero;
	
	i<-10;
	
	Mientras (i>=1) Hacer
		j<-1;
		Mientras (j <= i) Hacer
			Escribir Sin Saltar " ";
			
			j<-j+1;
		FinMientras
		
		
		Para  k <- 10  Hasta i Con Paso -1 Hacer
			
			Escribir Sin Saltar "*";
			
		FinPara
		i<-i-1;
		Escribir "";
		
	FinMientras
	
	
	
FinProceso


